      "source": [
        "from imblearn.over_sampling import SMOTE\n",
        "\n",
        "smote = SMOTE(random_state=42)\n",
        "\n",
        "X_train_smote, y_train_smote = smote.fit_resample(\n",
        "    X_train_scaled,\n",
        "    y_train\n",
        ")\n",
        "\n",
        "print(y_train_smote.value_counts())"
      ],
